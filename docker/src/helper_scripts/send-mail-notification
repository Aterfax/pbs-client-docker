#!/usr/bin/env bash

# $1 = STATUS, either "SUCCESS" or "FAILURE"
STATUS="$1"

# Validate STATUS
if [ "$STATUS" != "SUCCESS" ] && [ "$STATUS" != "FAILURE" ]; then
    echo "[mail][ERROR] Invalid status: $STATUS"
    exit 1
fi

# Exit silently if SMTP is not configured
[ -z "${SMTP_HOST:-}" ] && exit 0

HOSTNAME=$(hostname)
SUBJECT="[PBS] Backup ${STATUS} on ${HOSTNAME}"

# Compose email body
if [ "$STATUS" = "SUCCESS" ]; then
    BODY="Backup completed successfully on host ${HOSTNAME}."
else
    BODY="Backup failed on host ${HOSTNAME}. Please check logs for details."
fi

# Send the email via nullmailer
echo "${BODY}" | mail -s "${SUBJECT}" "${SMTP_TO}"

echo "[mail] Notification sent for status: ${STATUS}"