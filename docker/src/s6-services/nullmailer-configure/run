#!/usr/bin/with-contenv bash

# Define a logging function to prefix output to the docker logs.
output_to_log() {
    while IFS= read -r line; do
        echo "[mailer-configuration] $(date +"%Y-%m-%d %H:%M:%S") $line"
    done
}
# Redirect all subsequent command outputs to output_to_log
exec > >(output_to_log)

# Mail disabled if no relay defined
if [ -z "${SMTP_HOST:-}" ]; then
    echo "SMTP_HOST not set - email notifications disabled."
    exit 0
fi

echo "Configuring nullmailer relay → ${SMTP_HOST}:${SMTP_PORT}"

AUTH_FLAGS="--user=${SMTP_USER} --pass=${SMTP_PASSWORD}"
TLS_FLAGS=""

# Check for mutually exclusive TLS settings
if [ "${SMTP_TLS:-false}" = "true" ] && [ "${SMTP_STARTTLS:-false}" = "true" ]; then
    echo "[mail][WARNING] Both SMTP_TLS and SMTP_STARTTLS are set to true - these are mutually exclusive. Only one should be enabled. Defaulting to TLS, not STARTTLS."
fi

TLS_FLAGS=""
if [ "${SMTP_TLS:-true}" = "true" ]; then
    TLS_FLAGS="--ssl"
elif [ "${SMTP_STARTTLS:-false}" = "true" ]; then
    TLS_FLAGS="--starttls"
fi
cat >/etc/nullmailer/remotes <<EOF
${SMTP_HOST} smtp --port=${SMTP_PORT} ${AUTH_FLAGS} ${TLS_FLAGS}
EOF
chmod 600 /etc/nullmailer/remotes

echo "${SMTP_FROM}" >/etc/nullmailer/sendmail
hostname >/etc/mailname

mkdir -p /var/spool/nullmailer/queue
mkdir -p /var/spool/nullmailer/tmp

touch /var/spool/nullmailer/trigger

# nullmailer must own its spool
chown -R nullmail:nullmail /var/spool/nullmailer
chmod 750 /var/spool/nullmailer
chmod 700 /var/spool/nullmailer/{queue,tmp}
chmod 600 /var/spool/nullmailer/trigger

echo "nullmailer configured."